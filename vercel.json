{
  "version": 2,
  "builds": [
    { "src": "la-cle-institut/package.json", "use": "@vercel/next" },
    { "src": "la-cle-app/package.json", "use": "@vercel/next" }
  ],
  "routes": [
    {
      "src": "/acces-espace(?:/(.*))?$",
      "dest": "la-cle-app/$1"
    },
    {
      "src": "/(.*)",
      "dest": "la-cle-institut/$1"
    }
  ]
}
